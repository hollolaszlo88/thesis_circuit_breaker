    {
      "id": "M-08",
      "category": "triangle_geometry",
      "statement": "The sum of interior angles of a triangle is 360 degrees in Euclidean geometry.",
      "label": false,
      "notes": "Common false claim."
    },
    {
      "id": "M-09",
      "category": "triangle_geometry",
      "statement": "An equilateral triangle has all three sides equal.",
      "label": true,
      "notes": "Definition of equilateral triangle."
